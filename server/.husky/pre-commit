#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Run Jest tests
echo "🧪  Running tests..."
npm test
if [ $? -ne 0 ]; then
  echo "❌  Tests failed. Commit aborted."
  exit 1
fi

# Run case sensitivity check
echo "🔍  Checking for case-sensitive import issues..."
node scripts/check-case.js
if [ $? -ne 0 ]; then
  echo "❌  Case sensitivity check failed. Commit aborted."
  exit 1
fi
